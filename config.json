{
  "inbounds": [
    // 给 Back4App 用的 HTTP 健康检查端口
    {
      "type": "http",
      "listen": "::",
      "port": 8080,
      "users": []
    },
    // 你的代理服务（示例用 vless，按需修改）
    {
      "type": "vless",
      "listen": "::",
      "port": 8081,
      "protocol": "tcp",
      "settings": {
        "decryption": "none",
        "clients": [
          {
            "uuid": "0dc86002-3d43-4d83-ba4e-198bb11b82d2"
          }
        ]
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct"
    }
  ]
}
